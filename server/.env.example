# StudyMate AI Backend Environment Template
# Duplicate this file to .env inside the server directory.

PORT=5000

# Gemini AI API Key (Optional - Falls back to Simulated/Mock AI if left blank)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK credentials (Optional - Falls back to local JSON db if left blank)
# Alternative 1: Path to service account file
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Alternative 2: Direct Env keys
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
