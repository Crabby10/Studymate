# StudyMate AI gitignore

# Dependencies
client/node_modules/
server/node_modules/

# Local databases and uploads
server/db.json
server/uploads/*
!server/uploads/.gitkeep

# Environment files
.env
.env.local
client/.env
client/.env.local
server/.env
server/.env.local

# Logs and system
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
dist/
build/
.oxlintrc.json
